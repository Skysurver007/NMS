#!/bin/bash

# Script setup monitoring-wifi.service
# Jalankan dengan: sudo bash setup-monitoring.sh

# Warna untuk output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}=== Setup Monitoring WiFi Service ===${NC}"

# Step 1: Cek dan hapus file service jika ada
SERVICE_FILE="/etc/systemd/system/monitoring-wifi.service"

if [ -f "$SERVICE_FILE" ]; then
    echo -e "${YELLOW}File monitoring-wifi.service ditemukan, menghapus...${NC}"
    systemctl stop monitoring-wifi 2>/dev/null
    systemctl disable monitoring-wifi 2>/dev/null
    rm -f "$SERVICE_FILE"
    echo -e "${GREEN}File lama berhasil dihapus${NC}"
else
    echo -e "${GREEN}File monitoring-wifi.service tidak ditemukan, melanjutkan...${NC}"
fi

# Step 2: Buat file service baru
echo -e "${YELLOW}Membuat file service baru...${NC}"

cat > "$SERVICE_FILE" << 'EOF'
[Unit]
Description=Peycell NMS Monitoring Service
After=network.target

[Service]
User=root
WorkingDirectory=/root/monitoring-wifi
Environment=PATH=/root/monitoring-wifi/venv/bin

ExecStart=/root/monitoring-wifi/venv/bin/gunicorn --workers 1 --threads 4 --bind 0.0.0.0:5002 --timeout 120 app:app

Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF

echo -e "${GREEN}File service berhasil dibuat${NC}"

# Step 3: Reload systemd
echo -e "${YELLOW}Reloading systemd daemon...${NC}"
systemctl daemon-reload

# Step 4: Enable service
echo -e "${YELLOW}Mengaktifkan service...${NC}"
systemctl enable monitoring-wifi

# Step 5: Start service
echo -e "${YELLOW}Menjalankan service...${NC}"
systemctl start monitoring-wifi

# Step 6: Restart service (untuk memastikan)
echo -e "${YELLOW}Merestart service...${NC}"
systemctl restart monitoring-wifi

# Step 7: Cek status
echo -e "${GREEN}=== Status Service ===${NC}"
systemctl status monitoring-wifi --no-pager

echo -e "\n${GREEN}=== Setup Selesai ===${NC}"
