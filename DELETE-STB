#!/bin/bash

# Peycell NMS Monitoring Service - Install Script
# Author: [Your Name]
# Date: 2026-03-17

set -e

SERVICE_NAME="monitoring-wifi"
SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"
WORKING_DIR="/root/monitoring-wifi"
VENV_PATH="${WORKING_DIR}/venv/bin"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

echo_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

echo_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if running as root
if [ "$EUID" -ne 0 ]; then
    echo_error "Please run as root (use sudo)"
    exit 1
fi

# Check if working directory exists
if [ ! -d "$WORKING_DIR" ]; then
    echo_error "Working directory $WORKING_DIR not found!"
    exit 1
fi

# Check if virtual environment exists
if [ ! -d "$VENV_PATH" ]; then
    echo_error "Virtual environment not found at $VENV_PATH"
    exit 1
fi

echo_info "Installing $SERVICE_NAME service..."

# Create systemd service file
echo_info "Creating systemd service file..."
cat > "$SERVICE_FILE" << 'EOF'
[Unit]
Description=Peycell NMS Monitoring Service
After=network.target

[Service]
User=root
WorkingDirectory=/root/monitoring-wifi
Environment=PATH=/root/monitoring-wifi/venv/bin

ExecStart=/root/monitoring-wifi/venv/bin/gunicorn --workers 1 --threads 4 --bind 0.0.0.0:5002 --timeout 120 app:app

Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF

# Set permissions
chmod 644 "$SERVICE_FILE"

echo_info "Reloading systemd daemon..."
systemctl daemon-reload

echo_info "Enabling service to start on boot..."
systemctl enable "$SERVICE_NAME"

echo_info "Starting service..."
systemctl start "$SERVICE_NAME"

# Wait a moment and check status
sleep 2

echo_info "Checking service status..."
if systemctl is-active --quiet "$SERVICE_NAME"; then
    echo_info "✅ Service installed and running successfully!"
    echo_info "Service status:"
    systemctl status "$SERVICE_NAME" --no-pager
else
    echo_error "❌ Service failed to start. Check logs with: journalctl -u $SERVICE_NAME"
    exit 1
fi

echo ""
echo_info "Installation complete!"
echo_info "Useful commands:"
echo "  - Check status:  systemctl status $SERVICE_NAME"
echo "  - View logs:    journalctl -u $SERVICE_NAME -f"
echo "  - Restart:      systemctl restart $SERVICE_NAME"
echo "  - Stop:         systemctl stop $SERVICE_NAME"
